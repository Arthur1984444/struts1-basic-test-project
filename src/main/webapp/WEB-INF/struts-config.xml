<!DOCTYPE struts-config PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 1.3//EN"
        "http://struts.apache.org/dtds/struts-config_1_3.dtd">

<struts-config>

    <form-beans>
        <form-bean name="helloForm" type="com.example.HelloForm"/>
        <form-bean name="messageForm" type="com.example.MessageForm"/>
    </form-beans>

    <!-- Permet d'appeler la page d'accueil via son nom -->
    <global-forwards>
        <forward
                name="index"
                path="/index.jsp"/>
    </global-forwards>

    <!-- Permet d'appeler différentes actions via leur nom -->
    <action-mappings>
        <action path="/hello"
                type="com.example.HelloAction"
                name="helloForm"
                input="/index.jsp">

            <forward name="success" path="/result.jsp"/>
        </action>
        <action path="/message"
                type="com.example.MessageAction"
                name="messageForm"
                input="index.jsp">
            <forward name="test" path="/message.jsp"/>
        </action>
    </action-mappings>

</struts-config>